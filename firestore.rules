rules_version = '2';

// ============================================================
// REGLAS DE SEGURIDAD — Zephyr Token (simulador)
// ============================================================
// Pega este contenido en: Firebase Console > Firestore Database > Reglas
//
// Idea general:
// - Cualquier usuario autenticado puede leer su propio documento y el de otros
//   (para poder transferir/consultar), pero SOLO puede escribir en el suyo,
//   salvo que su propio documento tenga isAdmin == true.
// - El campo isAdmin NUNCA se puede fijar desde el cliente: solo tú puedes
//   activarlo manualmente desde la consola de Firebase (Firestore > users/{tuUID}).
// ============================================================

function isSignedIn() {
  return request.auth != null;
}

function isAdmin() {
  return isSignedIn() &&
    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
}

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if isSignedIn();

      // Un usuario puede crear su propio documento al registrarse,
      // pero nunca puede crearse a sí mismo como admin.
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.isAdmin == false;

      // Un usuario puede actualizar su propio documento, PERO nunca
      // puede cambiar su propio campo isAdmin. Un admin sí puede
      // modificar el documento de cualquiera (para otorgar saldo).
      allow update: if isSignedIn() && (
        (request.auth.uid == userId &&
          request.resource.data.isAdmin == resource.data.isAdmin)
        || isAdmin()
      );

      match /transactions/{txId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }
  }
}
